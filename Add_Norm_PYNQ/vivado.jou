export_simulation -lib_map_path [list {modelsim=/mnt/c/Study/Source/2026/Add_Norm_PYNQ/layernorm_w_dma.cache/compile_simlib/modelsim} {questa=/mnt/c/Study/Source/2026/Add_Norm_PYNQ/layernorm_w_dma.cache/compile_simlib/questa} {xcelium=/mnt/c/Study/Source/2026/Add_Norm_PYNQ/layernorm_w_dma.cache/compile_simlib/xcelium} {vcs=/mnt/c/Study/Source/2026/Add_Norm_PYNQ/layernorm_w_dma.cache/compile_simlib/vcs} {riviera=/mnt/c/Study/Source/2026/Add_Norm_PYNQ/layernorm_w_dma.cache/compile_simlib/riviera}] -of_objects [get_files /mnt/c/Study/Source/2026/Add_Norm_PYNQ/layernorm_w_dma.srcs/sources_1/bd/layernorm_dma_system/layernorm_dma_system.bd] -directory /mnt/c/Study/Source/2026/Add_Norm_PYNQ/layernorm_w_dma.ip_user_files/sim_scripts -ip_user_files_dir /mnt/c/Study/Source/2026/Add_Norm_PYNQ/layernorm_w_dma.ip_user_files -ipstatic_source_dir /mnt/c/Study/Source/2026/Add_Norm_PYNQ/layernorm_w_dma.ip_user_files/ipstatic -use_ip_compiled_libs -force -quiet
